<% 
  let currentUser = (typeof user !== 'undefined') ? user : null; 
%>

<header class="bg-white shadow-lg sticky top-0 z-50 border-b border-gray-100">
    <nav class="container mx-auto px-6 py-4 flex items-center justify-between">
        
        <a href="/" class="flex items-center group">
            <span class="text-3xl mr-3 transform group-hover:scale-110 transition-transform duration-300">🎁</span>
            <span class="text-2xl font-extrabold text-gray-900 group-hover:text-blue-600 transition-colors">
                Wishlist<span class="text-blue-600 group-hover:text-gray-900">App</span>
            </span>
        </a>

        <div class="hidden md:flex items-center space-x-8 font-medium text-gray-700">
            <a href="/" class="hover:text-blue-600 transition relative after:content-[''] after:absolute after:w-full after:h-0.5 after:bg-blue-600 after:bottom-[-4px] after:left-0 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300">Trang chủ</a>
            
            <% if (currentUser) { %>
                <a href="/" class="hover:text-blue-600 transition relative after:content-[''] after:absolute after:w-full after:h-0.5 after:bg-blue-600 after:bottom-[-4px] after:left-0 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300">Danh sách của tôi</a>
            <% } %>
            
            <a href="/explore" class="hover:text-blue-600 transition relative after:content-[''] after:absolute after:w-full after:h-0.5 after:bg-blue-600 after:bottom-[-4px] after:left-0 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300">Khám phá</a>
        </div>

        <div class="flex items-center space-x-3">
            <% if (currentUser) { %>
                <div class="flex items-center space-x-4">
                    <span class="text-sm font-medium text-gray-600 italic">
                        Chào, <span class="text-blue-600 font-bold"><%= currentUser.fullName %></span>
                    </span>
                    <a href="/auth/logout" class="bg-red-50 text-red-600 border border-red-200 px-5 py-2 rounded-full font-semibold hover:bg-red-600 hover:text-white transition-all duration-300">
                        Đăng xuất
                    </a>
                </div>
            <% } else { %>
                <a href="/auth/register" class="text-sm font-medium text-gray-600 hover:text-blue-600 transition">Đăng ký</a>
                <a href="/auth/login" class="bg-blue-600 text-white px-5 py-2.5 rounded-full font-semibold shadow-md hover:bg-blue-700 hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-300">
                    Đăng nhập
                </a>
            <% } %>
        </div>

    </nav>
</header>